NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=ciao@dietasprint.ai
NEXT_PUBLIC_LEGAL_CONTROLLER="Titolare da definire"
NEXT_PUBLIC_LEGAL_ADDRESS="Indirizzo sede da definire"
NEXT_PUBLIC_LEGAL_VAT="P.IVA / codice fiscale da definire"
NEXT_PUBLIC_DPO_EMAIL=

# Supabase
# Create a Supabase project, then copy Project URL and anon public key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin access
# Use Supabase Auth user metadata/app metadata for role=admin, or list trusted users here.
ADMIN_EMAILS=
ADMIN_USERNAMES=rdladmin

# Server-only keys must never be exposed in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Email
# Create a Resend API key with sending access for dietsprintai.com.
RESEND_API_KEY=
RESEND_FROM_EMAIL="DietaSprint AI <noreply@dietsprintai.com>"
PRIVACY_NOTIFICATION_EMAIL=
